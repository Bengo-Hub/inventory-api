# Inventory Service environment template
# Common env keys (uniform across all Go backends): POSTGRES_URL, REDIS_ADDR, REDIS_PASSWORD
APP_NAME=inventory-service
APP_ENV=development
APP_REGION=africa-east-1
APP_VERSION=0.1.0

HTTP_HOST=0.0.0.0
HTTP_PORT=4102
HTTP_READ_TIMEOUT=20s
HTTP_WRITE_TIMEOUT=20s
HTTP_IDLE_TIMEOUT=90s
# TLS configuration for HTTPS (mkcert certificates) - local development only
# Uncomment and set paths to enable HTTPS
# TLS_CERT_FILE=./config/certs/inventory.codevertex.local.pem
# TLS_KEY_FILE=./config/certs/inventory.codevertex.local-key.pem

POSTGRES_URL=postgres://postgres:postgres@localhost:5432/inventory?sslmode=disable
POSTGRES_MAX_OPEN_CONNS=30
POSTGRES_MAX_IDLE_CONNS=15
POSTGRES_CONN_MAX_LIFETIME=45m

REDIS_ADDR=localhost:6380
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS_REQUIRED=false
REDIS_DIAL_TIMEOUT=5s

EVENT_BUS=nats
NATS_URL=nats://localhost:4222
NATS_STREAM=inventory
NATS_DELIVER_GROUP=inventory-workers
NATS_DLQ_STREAM=inventory-dlq

OTLP_ENDPOINT=

# Auth Service SSO (JWT) settings
AUTH_SERVICE_URL=https://sso.codevertexitsolutions.com
AUTH_ISSUER=https://sso.codevertexitsolutions.com
AUTH_AUDIENCE=codevertex
AUTH_JWKS_URL=https://sso.codevertexitsolutions.com/api/v1/.well-known/jwks.json
AUTH_JWKS_CACHE_TTL=3600s
AUTH_JWKS_REFRESH_INTERVAL=300s

